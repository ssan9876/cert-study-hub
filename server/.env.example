# Copy to a file referenced by your process manager (e.g. /etc/cert-study-hub.env)
# and fill in real values. NEVER commit the real file.

# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-hex-string

# API listen settings (nginx reverse-proxies /api to this).
PORT=3001
HOST=127.0.0.1

# Where the SQLite database file lives.
DB_PATH=/var/lib/cert-study-hub/data.sqlite

# Set to "true" only when served over HTTPS so the session cookie is Secure.
COOKIE_SECURE=true
